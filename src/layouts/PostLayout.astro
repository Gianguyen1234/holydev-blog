---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import PostMeta from "../components/PostMeta.astro";
import AuthorNote from "../components/AuthorNote.astro";

type Entry =
  | CollectionEntry<"redis">
  | CollectionEntry<"distributed">
  | CollectionEntry<"database">
  | CollectionEntry<"concurrency">
  | CollectionEntry<"microservices">
  | CollectionEntry<"multi-module">;

const { entry, Content, headings, category, previousEntry, nextEntry, seriesEntries } = Astro.props as {
  entry: Entry;
  Content: any;
  headings: { depth: number; slug: string; text: string }[];
  category: string;
  previousEntry?: Entry | null;
  nextEntry?: Entry | null;
  seriesEntries?: Entry[];
};
const wordCount = entry.body ? entry.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 220));

const canonical = new URL(`/${category}/${entry.slug}`, Astro.site).toString();
const image =
  entry.data.image &&
  (Astro.site ? new URL(entry.data.image, Astro.site).toString() : entry.data.image);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  inLanguage: "vi-VN",
  url: canonical,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical
  },
  author: {
    "@type": "Person",
    name: "HolyDev"
  },
  publisher: {
    "@type": "Organization",
    name: "HolyDev"
  },
  keywords: entry.data.category,
  ...(image ? { image } : {})
};
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  openGraph={image ? { image } : undefined}
  pageType="article"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
    slot="head"
  />
  <script is:inline slot="head">
    (() => {
      const initCopyButtons = () => {
        const blocks = document.querySelectorAll(".post-layout article pre");

        blocks.forEach((block) => {
          if (block.parentElement?.classList.contains("code-block")) return;
          if (block.querySelector("[data-copy-code]")) return;

          const wrapper = document.createElement("div");
          wrapper.className = "code-block";
          block.parentNode?.insertBefore(wrapper, block);
          wrapper.appendChild(block);

          const button = document.createElement("button");
          button.type = "button";
          button.className = "code-copy-button";
          button.setAttribute("data-copy-code", "");
          button.textContent = "Copy";
          wrapper.appendChild(button);
        });
      };

      const copyCode = async (button) => {
        const block = button.closest(".code-block")?.querySelector("pre");
        const code = block?.querySelector("code");
        const text = code?.textContent;

        if (!text) return;

        try {
          await navigator.clipboard.writeText(text);
          const original = button.textContent;
          button.textContent = "Copied";
          button.dataset.copied = "true";
          window.setTimeout(() => {
            button.textContent = original ?? "Copy";
            delete button.dataset.copied;
          }, 1600);
        } catch {
          button.textContent = "Failed";
          window.setTimeout(() => {
            button.textContent = "Copy";
          }, 1600);
        }
      };

      document.addEventListener("DOMContentLoaded", initCopyButtons, { once: true });
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const button = target.closest("[data-copy-code]");
        if (!(button instanceof HTMLButtonElement)) return;

        copyCode(button);
      });
    })();
  </script>

  <div class="post-layout">
    <article class="content">
      <h1>{entry.data.title}</h1>
      <PostMeta
        pubDate={entry.data.pubDate}
        category={entry.data.category}
        readingTime={readingTime}
      />
      {entry.data.series && seriesEntries && seriesEntries.length > 0 ? (
        <section class="series-note">
          <div class="series-note-label">This article is part of</div>
          <div class="series-note-title">{entry.data.series}</div>
          <ol class="series-note-list">
            {seriesEntries.map((item) => {
              const isCurrent = item.slug === entry.slug;
              return (
                <li class:list={["series-note-item", isCurrent && "is-current"]}>
                  {isCurrent ? (
                    <span>{item.data.title}</span>
                  ) : (
                    <a href={`/${category}/${item.slug}`}>{item.data.title}</a>
                  )}
                </li>
              );
            })}
          </ol>
        </section>
      ) : null}
      <Content />
      <AuthorNote />
      <nav class="post-nav" aria-label="Article navigation">
        {previousEntry ? (
          <a class="post-nav-link" href={`/${category}/${previousEntry.slug}`}>
            <span class="post-nav-label">Previous article</span>
            <span class="post-nav-title">{previousEntry.data.title}</span>
          </a>
        ) : (
          <div class="post-nav-link post-nav-link-disabled" aria-hidden="true">
            <span class="post-nav-label">Previous article</span>
            <span class="post-nav-title">No previous article</span>
          </div>
        )}
        {nextEntry ? (
          <a class="post-nav-link" href={`/${category}/${nextEntry.slug}`}>
            <span class="post-nav-label">Next article</span>
            <span class="post-nav-title">{nextEntry.data.title}</span>
          </a>
        ) : (
          <div class="post-nav-link post-nav-link-disabled" aria-hidden="true">
            <span class="post-nav-label">Next article</span>
            <span class="post-nav-title">No next article</span>
          </div>
        )}
      </nav>
    </article>
  </div>
</BaseLayout>
