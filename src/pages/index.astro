---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories, categoryKeys } from "../config/categories";

const allEntries = (await Promise.all(categoryKeys.map((key) => getCollection(key)))).flat();

const latest = allEntries
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6)
  .map((entry) => ({
    entry,
    category: entry.collection
  }));
---
<BaseLayout
  title="Backend Engineer - System & Distributed Systems"
  description="Ghi ch&#250; k&#7929; thu&#7853;t chuy&#234;n s&#226;u v&#7873; system design, Redis, database internals, concurrency, and microservices."
>
  <section class="hero content">
    <h1 class="hero-title">Deep dives into backend systems.</h1>
    <p class="hero-subtitle">
      Redis replication, CAP tradeoffs, JVM concurrency, and the engineering decisions behind them.
    </p>
  </section>

  <section>
    <div class="section-title">Chuy&#234;n m&#7909;c</div>
    <div class="card-grid">
      {categoryKeys.map((key) => (
        <a class="card" href={`/${key}/`}>
          <h3>{categories[key].label}</h3>
          <p class="card-desc">{categories[key].description}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="section-title">B&#224;i m&#7899;i nh&#7845;t</div>
    <div class="post-list">
      {latest.map(({ entry, category }, index) => (
        <article class={`post-item${index === 0 ? " featured" : ""}`}>
          <h3>
            <a href={`/${category}/${entry.slug}`}>{entry.data.title}</a>
          </h3>
          <div class="post-meta">
            <span>{entry.data.category}</span>
            <span>&#8226;</span>
            <span>
              {new Date(entry.data.pubDate).toLocaleDateString("vi-VN", {
                year: "numeric",
                month: "long",
                day: "numeric"
              })}
            </span>
          </div>
          <p>{entry.data.description}</p>
        </article>
      ))}
    </div>
    <div class="section-action">
      <a class="section-link" href="/posts">View all posts</a>
    </div>
  </section>
</BaseLayout>
