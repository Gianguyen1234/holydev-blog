---
import { getCollection } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { categoryKeys } from "../../config/categories";

export async function getStaticPaths() {
  const entries = await Promise.all(
    categoryKeys.map(async (key) => ({
      key,
      items: (await getCollection(key)).sort(
        (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
      )
    }))
  );

  return entries.flatMap(({ key, items }) =>
    items.map((entry, index) => ({
      params: { category: key, slug: entry.slug },
      props: {
        entry,
        category: key,
        previousEntry: items[index - 1] ?? null,
        nextEntry: items[index + 1] ?? null
      }
    }))
  );
}

const { entry, category, previousEntry, nextEntry } = Astro.props;
const { Content, headings } = await entry.render();
const seriesEntries = entry.data.series
  ? (await getCollection(category))
      .filter((item) => item.data.series === entry.data.series)
      .sort((a, b) => {
        const orderA = a.data.seriesOrder ?? Number.MAX_SAFE_INTEGER;
        const orderB = b.data.seriesOrder ?? Number.MAX_SAFE_INTEGER;
        if (orderA !== orderB) return orderA - orderB;
        return a.data.pubDate.valueOf() - b.data.pubDate.valueOf();
      })
  : [];
---
<PostLayout
  entry={entry}
  Content={Content}
  headings={headings}
  category={category}
  previousEntry={previousEntry}
  nextEntry={nextEntry}
  seriesEntries={seriesEntries}
/>
