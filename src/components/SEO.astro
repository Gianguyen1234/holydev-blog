---
const {
  title,
  description,
  canonical,
  openGraph,
  pageType = "website"
} = Astro.props;

const defaultTitle = "HolyDev Blog";
const defaultDescription =
  "Ghi ch\u00FA chuy\u00EAn s\u00E2u v\u1EC1 system design, distributed systems, Redis, database internals v\u00E0 concurrency.";
const defaultImagePath = "/images/og/default-og.svg";

const metaTitle = title ? `${title} \u00B7 HolyDev` : defaultTitle;
const metaDescription = description ?? defaultDescription;
const canonicalUrl =
  canonical ?? (Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString());
const ogImage =
  openGraph?.image ??
  (Astro.site ? new URL(defaultImagePath, Astro.site).toString() : defaultImagePath);

const og = {
  title: openGraph?.title ?? metaTitle,
  description: openGraph?.description ?? metaDescription,
  type: openGraph?.type ?? pageType,
  url: openGraph?.url ?? canonicalUrl,
  image: ogImage
};
---
<title>{metaTitle}</title>
<meta name="description" content={metaDescription} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:title" content={og.title} />
<meta property="og:description" content={og.description} />
<meta property="og:type" content={og.type} />
<meta property="og:url" content={og.url} />
<meta property="og:image" content={og.image} />
<meta property="og:locale" content="vi_VN" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={og.title} />
<meta name="twitter:description" content={og.description} />
<meta name="twitter:image" content={og.image} />
