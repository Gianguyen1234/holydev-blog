---
const { headings } = Astro.props;
---
<aside class="toc">
  <div class="section-title">Mục lục</div>
  <nav>
    {headings?.length ? (
      <ul>
        {headings
          .filter((heading) => heading.depth <= 3)
          .map((heading) => (
            <li>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
      </ul>
    ) : (
      <div>Chưa có mục lục.</div>
    )}
  </nav>
</aside>
